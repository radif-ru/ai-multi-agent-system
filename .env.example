# --- Telegram ---
# Токен бота, полученный у @BotFather. Обязательная переменная.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Максимальный размер файла для скачивания из Telegram (МБ).
# Также используется как лимит для read_document.
TELEGRAM_MAX_FILE_MB=20

# --- MAX (мессенджер, dev.max.ru/docs-api) ---
# Токен бота: business.max.ru → Чат-боты → Интеграция → Получить токен.
# Если пусто — MAX-канал не запускается (запуск: python -m app.max_main).
# MAX_BOT_TOKEN=
# Базовый URL MAX Bot API (по умолчанию платформенный хост).
# MAX_API_BASE_URL=https://platform-api.max.ru
# Тайм-аут long polling в секундах (GET /updates).
# MAX_POLL_TIMEOUT=30
# Максимальный размер скачиваемого из MAX файла (МБ).
# MAX_MAX_FILE_MB=20

# --- Ollama (LLM) ---
# Базовый URL локального Ollama API (обычно http://localhost:11434).
OLLAMA_BASE_URL=http://localhost:11434
# Модель для агентного цикла (thought→action→observation). Должна
# присутствовать в OLLAMA_AVAILABLE_MODELS. Из ТЗ — qwen3.5:4b.
OLLAMA_DEFAULT_MODEL=qwen3.5:4b
# Список доступных моделей через запятую (теги из `ollama list`).
OLLAMA_AVAILABLE_MODELS=qwen3.5:4b,qwen3.5:0.8b,qwen3.6:35b,nomic-embed-text:latest,deepseek-r1:1.5b,llava:7b,gpt-oss:20b,kimi-k2.6:cloud
# Таймаут на один запрос к Ollama, секунды. С keep_alive и большими контекстами
# на мощной системе разумно держать с запасом.
OLLAMA_TIMEOUT=180
# Размер контекстного окна Ollama (num_ctx). 32768 умещается в VRAM (RTX 5090)
# и согласован с AGENT_MAX_CONTEXT_CHARS/MAX_DOCUMENT_CHARS (см. _docs/agent-loop.md §4).
OLLAMA_NUM_CTX=32768
# Reasoning-токены «думающей» модели (true/false). По умолчанию выключено:
# кратно быстрее, rationale агента и так выражен полем `thought`, а Ollama
# отбрасывает <think> из ответа. См. _docs/architecture.md §3.4.
OLLAMA_THINK=false
# Как долго Ollama держит модель резидентной между запросами (30m, 1h, 0=выгрузить
# сразу). Убирает холодные перезагрузки модели (на 24 ГБ безопасно).
OLLAMA_KEEP_ALIVE=30m
# Температура сэмплирования для chat. 0.0 — детерминированный вывод
# (предпочтительно для JSON-ответов агента).
OLLAMA_TEMPERATURE=0.0

# --- LLM gate (сериализация доступа к Ollama) ---
# Верхняя граница одновременных вызовов к Ollama (chat + embed) на весь процесс.
# Защищает от пайл-апов (live-запрос + фоновый journal_recovery), оставляя слот
# под live. На 24 ГБ две сессии к 4b @ num_ctx=32768 умещаются.
LLM_MAX_CONCURRENCY=2

# --- Ollama (Embeddings) ---
# Модель для семантической памяти (RAG). nomic-embed-text по умолчанию.
EMBEDDING_MODEL=nomic-embed-text
# Размерность вектора, должна соответствовать выбранной модели.
EMBEDDING_DIMENSIONS=768

# --- Agent loop ---
# Максимальное число итераций цикла thought→action→observation на одну задачу.
# Защита от бесконечного цикла, см. _docs/agent-loop.md §4.
AGENT_MAX_STEPS=10
# Максимальная длина ответа модели, который мы согласимся парсить как JSON
# (защита от мусора при неправильно отформатированном выводе).
AGENT_MAX_OUTPUT_CHARS=8000
# Порог суммаризации контекста (символы) перед отправкой в LLM: если контекст
# превышает лимит, история суммаризируется автоматически. Согласован с
# OLLAMA_NUM_CTX=32768 и MAX_DOCUMENT_CHARS, чтобы большой документ попадал в
# контекст без преждевременной суммаризации (см. _docs/agent-loop.md §4).
AGENT_MAX_CONTEXT_CHARS=90000

# --- Multi-agent (Planner + Critic), см. _docs/multi-agent.md ---
# Режим рефлексии: OFF — только Executor (поведение по умолчанию);
# NORMAL — один проход Critic после Executor;
# DEEP — итеративная рефлексия Critic, до AGENT_REFLECTION_MAX_ITERATIONS раз.
AGENT_REFLECTION_MODE=OFF
# Верхняя граница итераций Critic в режиме DEEP (только для DEEP).
AGENT_REFLECTION_MAX_ITERATIONS=2

# --- Memory (краткосрочная, in-memory) ---
# Жёсткий лимит на количество сообщений в истории одного пользователя.
# При превышении самые старые сообщения удаляются (FIFO).
HISTORY_MAX_MESSAGES=20
# Порог количества сообщений, при достижении которого старая часть истории
# сжимается LLM в краткое резюме. Должно быть > 0 и <= HISTORY_MAX_MESSAGES.
HISTORY_SUMMARY_THRESHOLD=10
# Верхняя страховка размера полного лога сессии (см. _docs/memory.md §2.5).
# Полный лог — параллельный append-only буфер, который cmd_new передаёт в
# Archiver. Защищает от аномально длинных сессий без /new. При переполнении
# отбрасывается голова и пишется WARNING.
SESSION_LOG_MAX_MESSAGES=1000
# System prompt суммаризации хранится в app/prompts/summarizer.md (см. _docs/prompts.md §2).
# Порог числа сообщений для перехода в map-reduce при суммаризации длинных
# логов сессии (см. _docs/memory.md §3.3). При len(messages) > порога:
# режем лог на батчи по N сообщений, суммаризуем каждый (map), затем сводим
# мини-саммари в одно итоговое (reduce).
SUMMARIZER_CHUNK_MESSAGES=30

# --- Memory (долгосрочная, sqlite-vec) ---
# Путь к файлу SQLite-БД с расширением sqlite-vec.
# Каталог создаётся автоматически. См. _docs/memory.md.
MEMORY_DB_PATH=data/memory.db
# Размер чанка саммари в символах при /new. См. _docs/memory.md §3.
MEMORY_CHUNK_SIZE=1500
# Перекрытие соседних чанков (символов).
MEMORY_CHUNK_OVERLAP=150
# Сколько чанков возвращать при поиске по семантической памяти.
MEMORY_SEARCH_TOP_K=5
# Параллелизм при вычислении embedding для чанков (оптимизация /new).
# Значение по умолчанию: 5. Увеличение ускоряет архивацию, но увеличивает нагрузку на Ollama.
EMBEDDING_CONCURRENCY=5
# Авто-подгрузка архива в первый ход новой сессии (см. _docs/memory.md §3.6).
# При len(history) == 1 core.handle_user_task делает embed + search и
# подмешивает найденные чанки одним system-сообщением. true | false.
SESSION_BOOTSTRAP_ENABLED=true
# Сколько чанков подмешивать при авто-подгрузке.
SESSION_BOOTSTRAP_TOP_K=3

# --- Journal recovery (фоновое восстановление висящих сессий) ---
# Параллелизм восстановления: 1 = последовательно, чтобы фоновый recovery не
# занимал все слоты LLM-gate и оставлял слот под live-запрос (см. _docs/memory.md §4.4).
JOURNAL_RECOVERY_CONCURRENCY=1
# Порог суммарного content сессии (символы): «мусор» ниже порога закрывается
# без LLM-вызова (нечего архивировать). 0 = пропуск отключён.
JOURNAL_RECOVERY_MIN_CHARS=50
# Пауза (секунды) перед запуском восстановления, чтобы не штормить Ollama сразу
# после старта, когда пользователь активен. 0 = без задержки.
JOURNAL_RECOVERY_START_DELAY=20

# --- System prompt (главный) ---
# Путь к markdown-файлу системного промпта агента, относительно корня репо.
# См. app/prompts/README.md и app/prompts/agent_system.md.
AGENT_SYSTEM_PROMPT_PATH=app/prompts/agent_system.md

# --- Logging ---
# Уровень логов: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=DEBUG
# Уровень логов для консоли: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL_CONSOLE=DEBUG
# Уровень логов для файла: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL_FILE=INFO
# Путь к файлу логов (каталог создастся автоматически).
LOG_FILE=logs/agent.log
# Логировать ли полный контекст (payload) перед каждым LLM-запросом.
# true | false. При false в лог пишутся только размеры (messages=, tokens=).
LOG_LLM_CONTEXT=true

# --- Temporary files ---
# Директория для временных файлов (скачанные из Telegram, обработанные документы).
# Каталог создаётся автоматически при старте.
TMP_BASE_DIR=data/tmp
# Максимальное количество символов в выводе любого tool'а (защита от слишком длинных ответов).
MAX_TOOL_OUTPUT_CHARS=50000
# Настройки для чтения документов (PDF, TXT, MD)
# Максимальное количество символов для чтения документа. Держится ниже
# AGENT_MAX_CONTEXT_CHARS, чтобы документ попадал в контекст без суммаризации.
MAX_DOCUMENT_CHARS=80000
# Максимальное количество картинок для OCR из PDF.
DOCUMENT_MAX_IMAGES=20
# Включить OCR для извлечения текста из изображений в PDF.
# Требует установки tesseract-ocr на системе.
DOCUMENT_OCR_ENABLED=true
# Языки для OCR (tesseract), через '+'. Например: rus+eng.
OCR_DEFAULT_LANG=rus+eng
# Порог: если извлечённого из PDF текста меньше N символов — запускается OCR.
OCR_MIN_TEXT_THRESHOLD=100

# --- Whisper (speech-to-text) ---
# Модель Whisper для распознавания речи (base, small, medium, large).
# См. https://github.com/SYSTRAN/faster-whisper
WHISPER_MODEL=base
# Язык для распознавания (ru, en, etc.).
WHISPER_LANGUAGE=ru

# --- Vision (image description) ---
# Модель Ollama для описания изображений.
# Рекомендации: gemma3:4b (по умолчанию), llava-phi3 (быстрее), qwen2.5-vl:7b (таблицы/диаграммы).
# См. _docs/vision-models.md
VISION_MODEL=gemma3:4b

# --- Web search ---
# Поисковик по умолчанию (duckduckgo, bing, google, brave, searxng).
# Сейчас реализован только duckduckgo, остальные — для будущих задач.
SEARCH_ENGINE_DEFAULT=duckduckgo
# Список доступных поисковиков через запятую.
SEARCH_ENGINES_AVAILABLE=duckduckgo

# --- Observability / error tracking (GlitchTip / Sentry) ---
# DSN self-hosted GlitchTip (Sentry-совместимый). Пустое значение =
# error tracking выключен: никаких сетевых запросов, бот стартует как обычно.
# Пример: https://<public_key>@glitchtip.example.com/<project_id>
SENTRY_DSN=
# Имя окружения, попадает в тег event.environment (dev | staging | prod).
SENTRY_ENVIRONMENT=dev
# Доля запросов, для которых снимается performance-трассировка (0.0 — только ошибки).
SENTRY_TRACES_SAMPLE_RATE=0.0

# --- Security ---
# Allowlist опасных tools (http_request, read_file). Secure by default:
# если переменной нет или она пустая — все опасные tools ЗАПРЕЩЕНЫ.
# Чтобы разрешить — раскомментируйте строку ниже и оставьте только нужные:
# DANGEROUS_TOOLS_ALLOWLIST=http_request,read_file
